rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : null;
    }

    function isSuperAdmin() {
      return role() == 'superadmin';
    }

    function isManager() {
      return role() in ['manager', 'superadmin'];
    }

    function isEditor() {
      return role() in ['editor', 'manager', 'superadmin'];
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isImage() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /products/{productId}/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isImage();
    }

    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage();
    }

    match /reviews/{userId}/{reviewId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isOwner(userId) || isManager();
    }

    match /payments/{userId}/{orderId}/{fileName} {
      allow read: if isManager();
      allow write: if isOwner(userId)
        && request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isSuperAdmin();
    }

    match /admin/{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
